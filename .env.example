# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=salary_management_development

# Rails
RAILS_ENV=development
SECRET_KEY_BASE=replace_with_output_of_rails_secret

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001

# Frontend → Backend proxy (Next.js server-side; not exposed to the browser)
BACKEND_URL=http://localhost:3000

# Left empty: browser fetches use relative paths proxied by Next.js SSR
NEXT_PUBLIC_API_URL=

# Frontend port
PORT=3001
